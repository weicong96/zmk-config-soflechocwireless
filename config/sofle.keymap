#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/ext_power.h>

/ {
    behaviors {
        /*
         * Homerow mod hold-tap behavior
         *
         * flavor = "balanced":
         *   - If you tap and release before tapping another key в†’ letter
         *   - If you hold past tapping-term OR press+release another key while held в†’ modifier
         *   This is the best all-round flavor for homerow mods.
         *
         * tapping-term-ms = 280:
         *   Time in ms to distinguish tap vs hold. 200вЂ“300 is typical;
         *   raise it if you get accidental mods, lower if holds feel sluggish.
         *
         * quick-tap-ms = 175:
         *   If you tap the key within this time of a previous tap of the SAME key,
         *   it always registers as a tap (not a hold). This allows fast repeated
         *   letter typing without triggering the modifier.
         *
         * require-prior-idle-ms = 150:
         *   Key must be idle for this long before a hold activates the modifier.
         *   Prevents accidental mods during fast typing rolls.
         */
        hm: homerow_mods {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "balanced";
            tapping-term-ms = <280>;
            quick-tap-ms = <175>;
            require-prior-idle-ms = <150>;
            bindings = <&kp>, <&kp>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
// в•­в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”¬в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”¬в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”¬в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”¬в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”¬в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв•®                         в•­в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”¬в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”¬в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”¬в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”¬в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”¬в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв•®
// в”‚    ESC  в”‚    1     в”‚    2     в”‚    3     в”‚    4     в”‚    5     в”‚                         в”‚    6     в”‚    7     в”‚    8     в”‚    9     в”‚    0     в”‚    BSPC в”‚
